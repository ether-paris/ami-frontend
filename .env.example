# Ami French Tutor - Environment Configuration

# Required for Mistral AI API
MISTRAL_API_KEY=your_mistral_api_key_here

# Google OAuth Configuration
# Get this from Google Cloud Console
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Authentication Secret
# Generate with: openssl rand -hex 32
GOOGLE_OAUTH_AUTH_SECRET=your_32_character_hex_secret_here

# Database (SQLite)
# Database will be created automatically at: ~/data/tutor.db

# Domain Configuration
DOMAIN=ami.ether.paris
DEV_DOMAIN=localhost:5173